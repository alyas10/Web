```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled and build artifacts
*.o
*.obj
*.so
*.a
*.dll
*.exe
*.out

# Dependencies
.venv/
venv/
env/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage and testing
.coverage
coverage/
htmlcov/
.pytest_cache/
.mypy_cache/

# Distribution artifacts
dist/
build/
target/
```